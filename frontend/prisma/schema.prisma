generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model User {
  id               String          @id @default(cuid())
  email            String          @unique
  name             String?
  passwordHash     String?
  role             UserRole        @default(LAWYER)
  orsrExtractType  String          @default("CURRENT") // CURRENT | FULL
  crzDateFrom      DateTime?       // CRZ dátum "od" — null = defaultne 1 rok dozadu
  defaultSources   String[]        @default([]) // Predvolené registre pre používateľa
  tokenVersion     Int             @default(0)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  reportRequests   ReportRequest[]
  feedback         Feedback[]
}

model ReportRequest {
  id              String              @id @default(cuid())
  userId          String
  status          ReportStatus        @default(PENDING)
  targetType      TargetType
  ico             String?
  companyName     String?
  selectedSources SourceType[]
  resultUrl       String?
  resultFilePath  String?
  completedAt     DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  sources         ReportSource[]

  @@index([userId, createdAt])
  @@index([status])
}

model ReportSource {
  id              String        @id @default(cuid())
  reportRequestId String
  sourceType      SourceType
  status          SourceStatus  @default(PENDING)
  statusMessage   String?
  filePath        String?
  pageCount       Int?
  findings        String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  reportRequest   ReportRequest @relation(fields: [reportRequestId], references: [id], onDelete: Cascade)

  @@unique([reportRequestId, sourceType])
  @@index([reportRequestId])
  @@index([sourceType])
  @@index([status])
}

enum UserRole {
  LAWYER
  ADMIN
}

enum ReportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  PARTIAL
}

enum TargetType {
  COMPANY
}

enum SourceType {
  ORSR
  ZRSR
  RPO
  RPVS
  OBCHODNY_VESTNIK
  INSOLVENCY
  POVERENIA
  FINANCNA_SPRAVA
  SP_DLZNICI
  VSZP_DLZNICI
  DOVERA_DLZNICI
  UNION_DLZNICI
  CRRS
  DISKVALIFIKACIE
  NCRZP
  NCRD
  OCHRANNE_ZNAMKY
  FS_DANOVE_SUBJEKTY
  FS_DPH_REGISTROVANI
  FS_DPH_RUSENIE
  FS_DPH_VYMAZANI
  FS_DPH_NADMERNY_ODPOCET
  FS_DPH_BANKOVE_UCTY
  FS_DAN_Z_PRIJMOV
  FS_DAN_PRIJMOV_REG
  REGISTER_UZ
  CRZ
  UVO
}

enum SourceStatus {
  PENDING
  SUCCESS
  FAILED
  UNAVAILABLE
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())

  @@unique([email, token])
  @@index([email])
  @@index([expires])
}

enum FeedbackCategory {
  BUG
  IMPROVEMENT
  QUESTION
  OTHER
}

model Feedback {
  id         String          @id @default(cuid())
  userId     String
  category   FeedbackCategory
  requestId  String?
  message    String
  status     String          @default("OPEN") // OPEN | RESOLVED | CLOSED
  reply      String?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

enum MessageType {
  ANNOUNCEMENT
  REPLY
  SYSTEM
}

model UserMessage {
  id         String          @id @default(cuid())
  userId     String?
  type        MessageType
  title       String
  body        String
  read        Boolean         @default(false)
  feedbackId  String?
  createdAt   DateTime        @default(now())

  @@index([userId])
  @@index([read])
}
