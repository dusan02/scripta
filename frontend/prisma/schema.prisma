generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x", "linux-arm64-openssl-1.1.x", "debian-openssl-3.0.x", "debian-openssl-1.1.x"]
}

generator client_py {
  provider             = "prisma-client-py"
  output               = "../../worker/venv/lib/python3.9/site-packages/prisma"
  enable_experimental_decimal = true
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model User {
  id               String          @id @default(cuid())
  email            String          @unique
  name             String?
  passwordHash     String?
  emailVerified    DateTime?
  role             UserRole        @default(LAWYER)
  orsrExtractType  String          @default("CURRENT") // CURRENT | FULL
  crzDateFrom      DateTime?       // CRZ dátum "od" — null = defaultne 1 rok dozadu
  rozhodnutiaDateFrom DateTime?    // Rozhodnutia dátum "od" — null = defaultne 1 rok dozadu
  vestnikDateFrom  DateTime?       // Vestník dátum "od" — null = defaultne 1 rok dozadu
  defaultSources   String[]        @default([]) // Predvolené registre pre používateľa
  reportLanguage   String          @default("sk") // sk | en | de — jazyk PDF reportu
  tokenVersion     Int             @default(0)
  planName           String?         // Názov paušálu (start, freelance, firma, korporat)
  planRenewalDate    DateTime?       // Dátum obnovenia paušálu
  trialEndsAt        DateTime?       // Koniec skúšobného obdobia (5 zadarmo kreditov na mesiac)
  subscriptionStatus String?         // active | canceled | past_due | trialing
  subscriptionEndsAt DateTime?       // Dátum ukončenia predplatného (pre zrušené)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  reportRequests     ReportRequest[]
  feedback           Feedback[]
  wallet             Wallet?
  creditBatches      CreditBatch[]
  messages           UserMessage[]      @relation("UserMessages")
  sentMessages       UserMessage[]      @relation("SentMessages")
}

model ReportRequest {
  id              String              @id @default(cuid())
  userId          String
  status          ReportStatus        @default(PENDING)
  targetType      TargetType
  ico             String?
  companyName     String?
  selectedSources SourceType[]
  resultUrl       String?
  resultFilePath  String?
  completedAt     DateTime?
  aiStatus        String?
  eta             Int?
  verifaScore     Int?                // Snapshot skóre fixované pri generovaní reportu
  scrapersMs      Int?                // Duration of scraper phase in ms
  aiMs            Int?                // Duration of AI pipeline phase in ms
  auditorMs       Int?                // Duration of Chief Auditor phase in ms
  compileMs       Int?                // Duration of PDF compilation phase in ms
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  sources         ReportSource[]

  @@index([userId, createdAt])
  @@index([status])
}

model ReportSource {
  id              String        @id @default(cuid())
  reportRequestId String
  sourceType      SourceType
  status          SourceStatus  @default(PENDING)
  statusMessage   String?
  filePath        String?
  pageCount       Int?
  findings        String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  reportRequest   ReportRequest @relation(fields: [reportRequestId], references: [id], onDelete: Cascade)

  @@unique([reportRequestId, sourceType])
  @@index([reportRequestId])
  @@index([sourceType])
  @@index([status])
}

enum UserRole {
  LAWYER
  ADMIN
}

enum ReportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  PARTIAL
}

enum TargetType {
  COMPANY
}

enum SourceType {
  ORSR
  ZRSR
  RPO
  RPVS
  OBCHODNY_VESTNIK
  INSOLVENCY
  POVERENIA
  FINANCNA_SPRAVA
  SP_DLZNICI
  VSZP_DLZNICI
  DOVERA_DLZNICI
  UNION_DLZNICI
  CRRS
  DISKVALIFIKACIE
  NCRZP
  NCRD
  OCHRANNE_ZNAMKY
  FS_DANOVE_SUBJEKTY
  FS_DPH_REGISTROVANI
  FS_DPH_RUSENIE
  FS_DPH_VYMAZANI
  FS_DPH_NADMERNY_ODPOCET
  FS_DPH_BANKOVE_UCTY
  FS_DAN_Z_PRIJMOV
  FS_DAN_PRIJMOV_REG
  REGISTER_UZ
  CRZ
  UVO
  ROZHODNUTIA
}

enum SourceStatus {
  PENDING
  SUCCESS
  FAILED
  UNAVAILABLE
}

model VerificationToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())

  @@unique([email, token])
  @@index([email])
  @@index([expires])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())

  @@unique([email, token])
  @@index([email])
  @@index([expires])
}

enum FeedbackCategory {
  BUG
  IMPROVEMENT
  QUESTION
  OTHER
}

model Feedback {
  id         String          @id @default(cuid())
  userId     String
  category   FeedbackCategory
  requestId  String?
  message    String
  status     String          @default("OPEN") // OPEN | RESOLVED | CLOSED
  reply      String?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

enum MessageType {
  ANNOUNCEMENT
  REPLY
  SYSTEM
  USER
}

model UserMessage {
  id         String          @id @default(cuid())
  userId     String?
  senderId   String?
  type        MessageType
  title       String
  body        String
  read        Boolean         @default(false)
  feedbackId  String?
  createdAt   DateTime        @default(now())

  user   User? @relation("UserMessages", fields: [userId], references: [id], onDelete: Cascade)
  sender User? @relation("SentMessages", fields: [senderId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([senderId])
  @@index([read])
}

model Company {
  ico                 String               @id
  name                String?
  naceCode            String?
  naceText            String?
  financialStatements FinancialStatement[]
  vestnikEvents       VestnikEvent[]
  companyEvents       CompanyEvent[]
  auditVerdict        AuditVerdict?
}

model CompanyEvent {
  id           String   @id @default(uuid())
  companyIco   String
  source       String   // ROZHODNUTIA, INSOLVENCY, DISKVALIFIKACIE, DOVERA, VSZP, SP, UNION, FS_DAN, FS_DPH, CRZ, UVO, VESTNIK
  eventType    String   // SUDNE_ROZHODNUTIE, INSOLVENCIA, DISKVALIFIKACIA, POISTOVNA_DLUH, DAN_NEDOPLATOK, VEREJNA_ZMLUVA, OBSTARAVANIE, VESTNIK_UDALOST
  severity     String   // CRITICAL, HIGH, MEDIUM, LOW, INFO
  title        String   // Krátky názov udalosti
  description  String   @db.Text // Detailný popis
  eventDate    DateTime? // Dátum udalosti (ak známy z PDF)
  amount       Float?   // Finančná hodnota (napr. výška nedoplatku, suma zmluvy)
  metadata     Json?    // Dodatočné dáta (súd, číslo spisu, IČO protistrany...)
  createdAt    DateTime @default(now())

  company      Company  @relation(fields: [companyIco], references: [ico])

  @@index([companyIco])
  @@index([severity])
}

model VestnikEvent {
  id              String   @id @default(uuid())
  companyIco      String
  eventType       String   // Konkurz, Exekúcia, Zmena...
  severityLevel   String   // CRITICAL, HIGH, MEDIUM, LOW
  summary         String   @db.Text
  publishedAt     DateTime // Dátum vydania vo vestníku
  sourceId        String?  // Identifikátor z XML feedu (napr. číslo vydania/záznamu)
  createdAt       DateTime @default(now())

  company         Company  @relation(fields: [companyIco], references: [ico])

  @@index([companyIco])
  @@index([severityLevel])
}

model FinancialStatement {
  id                                    String          @id @default(uuid())
  companyIco                            String
  year                                  Int
  totalAssets                           Float?
  currentAssets                         Float?
  equity                                Float?
  shortTermLiabilities                  Float?
  longTermLiabilities                   Float?        // Dlhodobé záväzky (bankové úvery, dlhopisy...)
  mainActivityRevenue                   Float?
  grossProfit                           Float?        // Hrubý zisk (Revenue - COGS) — pre obchodné firmy
  netProfitLoss                         Float?
  cashAndEquivalents                    Float?
  operatingCashFlow                     Float?
  staffCosts                            Float?        // Osobné náklady
  tradeReceivables                      Float?        // Pohľadávky z obch. styku
  tradePayables                         Float?        // Záväzky z obch. styku
  inventory                             Float?        // Zásoby
  depreciation                          Float?        // Odpisy dlhodobého nehmotného a hmotného majetku
  investingCashFlow                     Float?        // Čisté peňažné toky z investičnej činnosti
  financingCashFlow                     Float?        // Čisté peňažné toky z finančnej činnosti
  interestExpense                       Float?        // Úroky (náklady na úroky)
  employeeCount                         Int?          // Odhadovaný počet zamestnancov
  currency                              String        @default("EUR") // Mena výkazu (EUR, CZK, USD...)
  statementType                         String        @default("SK_GAAP") // IFRS | SK_GAAP | MICRO
  monthsInPeriod                        Int?          @default(12) // Pre posunuté/kratšie hospodárske roky
  isConsolidated                        Boolean       @default(false)
  createdAt                             DateTime        @default(now())
  
  company                               Company         @relation(fields: [companyIco], references: [ico])
  auditorOpinion                        AuditorOpinion?
  narrativeRisk                         NarrativeRiskAnalysis?
  notesRisk                             NotesRiskAnalysis?

  @@unique([companyIco, year]) // Zabezpečí, že nebudeme mať duplicitné výkazy za jeden rok
}


model AuditorOpinion {
  id                   String             @id @default(uuid())
  financialStatementId String             @unique
  opinionType          String             
  goingConcernRisk     Boolean
  reservationText      String?
  
  statement            FinancialStatement @relation(fields: [financialStatementId], references: [id])
}

model NarrativeRiskAnalysis {
  id                       String             @id @default(uuid())
  financialStatementId     String             @unique
  managementChanges        String?            @db.Text
  litigationRisks          String?            @db.Text
  goingConcernDoubts       Boolean
  plannedInvestments       String?            @db.Text
  profitabilityExplanation String?            @db.Text
  forensicRedFlags         String[]
  synthesis                String             @db.Text
  createdAt                DateTime           @default(now())

  statement                FinancialStatement @relation(fields: [financialStatementId], references: [id])
}

model NotesRiskAnalysis {
  id                      String             @id @default(uuid())
  financialStatementId    String             @unique
  relatedPartyTransactions String?           @db.Text
  offBalanceSheetLiabilities String?         @db.Text
  contingentRisks         String?            @db.Text
  createdAt               DateTime           @default(now())

  statement               FinancialStatement @relation(fields: [financialStatementId], references: [id])
}

model AuditVerdict {
  id              String   @id @default(uuid())
  companyIco      String   @unique
  verifaScore     Int
  riskCategory    String
  debtExposureRating Int?
  finalVerdict    String   @db.Text
  executiveSummary String? @db.Text
  justification   String   @db.Text
  keyRisk         String   @db.Text
  scorecardBreakdown Json?
  llmAnalysisStatus String @default("LLM_ANALYZED")
  createdAt       DateTime @default(now())

  company         Company  @relation(fields: [companyIco], references: [ico])
}

model CreditBatch {
  id          String   @id @default(cuid())
  userId      String
  amount      Int      // Pôvodný počet kreditov v batchi
  remaining   Int      // Koľko ostáva k dispozícii
  source      String   // trial | subscription | addon | rollover
  planName    String?
  expiresAt   DateTime // 90 dní od vytvorenia
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([userId, createdAt])
}

model Wallet {
  id        String   @id @default(cuid())
  userId    String   @unique
  balance   Decimal  @default(0) @db.Decimal(10, 2)
  currency  String   @default("EUR")
  version   Int      @default(0) // Optimistic locking
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions    WalletTransaction[]

  @@index([userId])
}

enum TransactionType {
  CHARGE
  TOPUP
  REFUND
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
}

model WalletTransaction {
  id                   String             @id @default(cuid())
  walletId             String
  amount               Decimal            @db.Decimal(10, 2)
  type                 TransactionType
  status               TransactionStatus  @default(COMPLETED)
  reportRequestId      String?
  stripePaymentIntentId String?            @unique
  description          String?
  createdAt            DateTime           @default(now())

  wallet               Wallet             @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@index([reportRequestId])
}

