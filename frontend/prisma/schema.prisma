generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model User {
  id               String          @id @default(cuid())
  email            String          @unique
  name             String?
  passwordHash     String?
  role             UserRole        @default(LAWYER)
  orsrExtractType  String          @default("CURRENT") // CURRENT | FULL
  tokenVersion     Int             @default(0)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  reportRequests   ReportRequest[]
}

model ReportRequest {
  id              String              @id @default(cuid())
  userId          String
  status          ReportStatus        @default(PENDING)
  targetType      TargetType
  ico             String?
  companyName     String?
  name            String?
  surname         String?
  birthDate       DateTime?
  selectedSources SourceType[]
  resultUrl       String?
  resultFilePath  String?
  completedAt     DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  sources         ReportSource[]

  @@index([userId, createdAt])
  @@index([status])
}

model ReportSource {
  id              String        @id @default(cuid())
  reportRequestId String
  sourceType      SourceType
  status          SourceStatus  @default(PENDING)
  statusMessage   String?
  filePath        String?
  pageCount       Int?
  findings        String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  reportRequest   ReportRequest @relation(fields: [reportRequestId], references: [id], onDelete: Cascade)

  @@unique([reportRequestId, sourceType])
  @@index([reportRequestId])
  @@index([sourceType])
  @@index([status])
}

enum UserRole {
  LAWYER
  ADMIN
}

enum ReportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  PARTIAL
}

enum TargetType {
  COMPANY
  PERSON
}

enum SourceType {
  ORSR
  ZRSR
  INSOLVENCY
  RPVS
  NCRZP
  NCRD
  FINANCNA_SPRAVA
  FS_DPH_RUSENIE
  FS_DPH_VYMAZANI
  FS_DANOVE_SUBJEKTY
  FS_DAN_Z_PRIJMOV
  FS_DPH_NADMERNY_ODPOCET
  FS_DPH_REGISTROVANI
  FS_DAN_PRIJMOV_REG
  SP_DLZNICI
  VSZP_DLZNICI
  DOVERA_DLZNICI
  UNION_DLZNICI
  REGISTER_UZ
}

enum SourceStatus {
  PENDING
  SUCCESS
  FAILED
  UNAVAILABLE
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())

  @@unique([email, token])
  @@index([email])
  @@index([expires])
}
