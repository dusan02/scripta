APP_ENV=development
DATABASE_URL=postgresql://user:password@localhost:5432/scripta
RESULTS_DIR=./results
WEB_CONCURRENCY=4
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT=60000

# Shared-secret medzi Next.js API a workerom (musí sa zhodovať s WORKER_SECRET vo frontende)
WORKER_SECRET=change_me_worker_secret

# CRE — Centrálny register exekúcií (voliteľné)
CRE_USERNAME=
CRE_PASSWORD=
